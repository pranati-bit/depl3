<!DOCTYPE html>
<html>
<head>
<title>Student Search</title>
</head>

<body>

<h2>Search Student</h2>

<form method="POST">
<input type="text" name="search" placeholder="Enter Name or SAP ID">
<button type="submit">Search</button>
</form>

{% if student %}

<h3>Student Details</h3>

<p>Name: {{student[0]}}</p>
<p>SAP ID: {{student[1]}}</p>
<p>Course: {{student[2]}}</p>
<p>Roll Number: {{student[3]}}</p>
<p>GPA: {{student[4]}}</p>

{% endif %}

</body>
</html>
